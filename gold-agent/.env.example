# Gold Trading Agent — Environment Variables
# Copy this file to .env and fill in your actual keys:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
# Your OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# NewsAPI key for live gold news (get one free at https://newsapi.org)
# If not set, the app uses realistic mock headlines automatically.
NEWS_API_KEY=your_key_here

# USD to Thai Baht exchange rate (update daily for accuracy)
# Source: https://www.bot.or.th or any forex provider
USD_THB_RATE=34.5

# MongoDB Atlas connection string (get one free at https://mongodb.com/atlas)
# If not set, the app uses local JSON/CSV files automatically.
MONGODB_URI=your_mongodb_uri_here

# ── Background Scheduler ──────────────────────────────────────────────────────
# How often the background trade loop runs (seconds). Default: 300 (5 min).
# Lower for testing (e.g. 60), keep at 300 for production to match dashboard cadence.
TRADE_LOOP_INTERVAL_SEC=300

# ── Trading Fees ───────────────────────────────────────────────────────────────
# Applied on EVERY trade (both open and close).
# Hua Seng Heng ออมทอง: ~0.5% spread per side + 0 flat fee.
# Set both to 0 to run fee-free (pure paper trading).
TRADE_FEE_PCT=0.005        # percentage of trade value per transaction (0.005 = 0.5%)
TRADE_FEE_FLAT_THB=0       # flat fee in THB per transaction (e.g. 15 for some brokers)
