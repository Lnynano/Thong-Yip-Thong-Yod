# ==============================================================================
# Gold Trading Agent — Environment Variables
# Copy this file to .env and fill in your actual keys:
#   cp .env.example .env
# ==============================================================================

# ── 1. API Keys (Core) ────────────────────────────────────────────────────────
# Your OpenAI API key (Required for LLM analysis)
OPENAI_API_KEY=your_key_here

# NewsAPI key for live gold news (If not set, uses realistic mock headlines)
NEWS_API_KEY=your_key_here

# Anthropic API Key (Alternative LLM, currently unused)
#ANTHROPIC_API_KEY=your_key_here

# ── 2. Database & Integrations ────────────────────────────────────────────────
# MongoDB Atlas connection string (If not set, uses local JSON/CSV files)
MONGODB_URI=your_mongodb_uri_here

# Discord Webhook URL for BUY/SELL signal alerts (@everyone on trades)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Professor's GoldTrade Logs API key (team-specific, from instructor)
# Every agent signal is auto-logged to the competition server.
TRADE_LOG_API_KEY=your_key_here

# ── 3. Trading & Economics ────────────────────────────────────────────────────
# USD to Thai Baht exchange rate (update daily for accuracy)
USD_THB_RATE=32.50

# Starting capital in THB (competition rule: 1,500 THB)
COMPETITION_BUDGET_THB=1500

# Applied on EVERY trade (both open and close).
# Hua Seng Heng ออมทอง: ~0.5% spread per side + 0 flat fee.
# Set both to 0 to run fee-free (pure paper trading).
TRADE_FEE_PCT=0
TRADE_FEE_FLAT_THB=0

# ── 4. App Configuration & UI ─────────────────────────────────────────────────
# Port for Gradio Server
PORT=7860

# Developer Mode (Enables extra UI toggles, backtest tab)
DEV_MODE=True

# How often the background trade loop in main.py runs (seconds). Default: 1800.
# Lower for testing (e.g. 60), keep at 1800 for production.
TRADE_LOOP_INTERVAL_SEC=1800

# ── 5. Backtesting Limits ─────────────────────────────────────────────────────
# 690 = 1 hour for 30 days | 1380 = 1 hour for 60 days
BACKTEST_MAX_CANDLES=230
